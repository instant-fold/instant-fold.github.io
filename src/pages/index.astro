---
import BaseLayout from "../layouts/BaseLayout.astro";
import { project } from "../data/project.js";
import rolloutModes from "../data/rollout-modes.generated.json";

const { hero, zeroShotSim2Real, flowMatching, videoSets, failureModes, abstract } = project;
const defaultSet = videoSets.pink;
const defaultFailureMode = failureModes?.modes?.[0] ?? null;
const serializedVideoSets = JSON.stringify(videoSets);
const serializedFailureModes = JSON.stringify(failureModes);
const defaultRolloutMode = rolloutModes.find((mode) => mode.group === "seen") ?? rolloutModes[0] ?? null;
const serializedRolloutModes = JSON.stringify(rolloutModes);
---

<BaseLayout title={`${hero.title} | ${project.site.name}`} description={project.site.description}>
  <main id="top" class="theme-sage-sand min-h-screen bg-white">
    <div class="mx-auto w-full max-w-6xl px-5 py-8 md:px-8 lg:py-12">
      <section class="mx-auto max-w-[65rem]">
        <h1 class="theme-hero-title font-poppins mb-5 bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600 bg-clip-text text-center text-4xl font-medium leading-tight text-transparent md:text-5xl">
          <span class="text-stone-800">{hero.title}</span>
        </h1>

        <p class="theme-venue font-poppins mb-6 text-center text-2xl font-semibold text-red-500">{hero.venue}</p>

        <div class="theme-authors font-poppins mb-6 flex flex-wrap justify-center gap-x-3 gap-y-2 text-center text-stone-800">
          {hero.authors.map((author) => (
            <span>
              {author.href ? (
                <a href={author.href} target="_blank" rel="noreferrer" class="hover:underline">
                  {author.name}
                </a>
              ) : (
                author.name
              )}
            </span>
          ))}
        </div>

        <!-- <div class="mb-8 flex flex-wrap justify-center gap-3">
          {hero.actions.map((action) => (
            <a
              href={action.href}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noreferrer" : undefined}
              class="theme-pill font-poppins rounded-2xl bg-stone-100 px-4 py-2 text-sm text-black no-underline"
            >
              {action.label}
            </a>
          ))}
        </div> -->

        <div class="mb-3">
          <video
            autoplay
            muted
            playsinline
            loop
            controls
            preload="metadata"
            class="mx-auto w-full rounded-xl sm:max-w-[95%]"
          >
            <source src={hero.teaserVideo} type="video/mp4" />
          </video>
        </div>

        <p class="copy-sans mx-auto mb-10 max-w-4xl text-center text-lg text-stone-700">
          {hero.teaserCaption}
        </p>

        <div class="space-y-4">
          <section class="theme-surface mx-auto w-full rounded-2xl bg-white p-2">
            <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">Abstract</h2>
            <div class="theme-copy copy-sans space-y-3 text-justify text-md text-stone-800">
              {abstract.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </section>

          <section class="theme-surface mx-auto w-full rounded-2xl bg-white p-6">
            <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">Overview</h2>
            <div class="overflow-hidden rounded-sm">
              <img
                src="/assets/images/overview.png"
                alt="Overview of Instant‑Fold"
                class="mx-auto h-auto w-[75%] object-contain"
              />
            </div>
            <p class="theme-copy copy-sans mt-3 text-justify text-md leading-7 text-stone-800">
              <span class="font-semibold">Overview of Instant‑Fold:</span>
              {' '}
              (1) We first pretrain a deformation-aware tokenizer with temporal contrastive supervision, lifting masked RGB-D observations into geo-semantic 3D cloth tokens. (2) During policy learning, the shared encoders tokenize both the demonstration and current observations, aggregate dense spatio-temporal demonstration context, and condition a flow-matching denoising transformer to reconstruct clean dual-arm action trajectories from noise.
            </p>
          </section>

          <section class="theme-surface mx-auto w-full rounded-2xl bg-white p-4">
            <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">
              Temporal Constrative Pretraining
            </h2>
            <div class="theme-subtle mb-4 rounded-2xl bg-stone-50/80 px-4 py-3 ring-1 ring-stone-100">
              <p class="theme-copy copy-sans text-center text-md leading-7 text-stone-700">
                We introduce a soft-weighted supervised contrastive objective to pretrain deformation-aware visual representation in simulation.
              </p>
            </div>
            <div class="grid gap-3 md:grid-cols-2">
              <figure class="overflow-hidden rounded-2xl p-3">
                <img
                  src="/assets/images/pretrain/self-match.png"
                  alt="Self-match pretraining illustration"
                  class="mx-auto h-auto w-full rounded-xl object-contain"
                />
              </figure>
              <figure class="overflow-hidden rounded-2xl p-3">
                <img
                  src="/assets/images/pretrain/cross-match.png"
                  alt="Cross-match pretraining illustration"
                  class="mx-auto h-auto w-full rounded-xl object-contain"
                />
              </figure>
            </div>
            <div class="theme-subtle mb-4 rounded-2xl bg-stone-50/80 px-4 py-3 ring-1 ring-stone-100">
              <p class="theme-copy copy-sans text-center text-md leading-7 text-stone-700">
                As a result, our visual encoder produces temporally consistent and spatially coherent representation for downstream manipulation.
              </p>
            </div>

            <div class="theme-meta mb-3 flex flex-wrap items-center justify-center gap-3 text-sm font-medium text-stone-600">
              <span class="text-stone-700">Slide for comparison:</span>
              <button type="button" data-baseline="unigarment" aria-pressed="true" class="baseline-pill px-1 py-1 text-sm font-medium text-stone-950">
                UniGarment
              </button>
              <button type="button" data-baseline="dino" aria-pressed="false" class="baseline-pill px-1 py-1 text-sm font-medium text-stone-600">
                DINOv3
              </button>
            </div>

            <div class="grid gap-3 md:grid-cols-2">
              <div class="cvpr-compare" data-compare data-left-unigarment="/assets/images/pretrain/realworld_shared_pca_unigarment_1.png" data-left-dino="/assets/images/pretrain/realworld_shared_pca_raw_dino_1.png" data-right-src="/assets/images/pretrain/realworld_shared_pca_ours_1.png">
                <img src="/assets/images/pretrain/realworld_shared_pca_unigarment_1.png" alt="Baseline representation comparison 1" class="compare-base" data-compare-base />
                <img src="/assets/images/pretrain/realworld_shared_pca_ours_1.png" alt="Ours representation comparison 1" class="compare-top" data-compare-top />
                <span class="compare-label compare-label-left">Ours</span>
                <span class="compare-label compare-label-right" data-compare-baseline-label>UniGarment</span>
                <div class="compare-handle" data-compare-handle>
                  <div class="compare-divider" data-compare-divider></div>
                  <div class="compare-arrows" aria-hidden="true">
                    <span class="compare-arrow left"></span>
                    <span class="compare-arrow right"></span>
                  </div>
                </div>
                <input type="range" min="0" max="100" value="50" aria-label="Compare representations 1" class="compare-slider" data-compare-slider />
              </div>

              <div class="cvpr-compare" data-compare data-left-unigarment="/assets/images/pretrain/realworld_shared_pca_unigarment_2.png" data-left-dino="/assets/images/pretrain/realworld_shared_pca_raw_dino_2.png" data-right-src="/assets/images/pretrain/realworld_shared_pca_ours_2.png">
                <img src="/assets/images/pretrain/realworld_shared_pca_unigarment_2.png" alt="Baseline representation comparison 2" class="compare-base" data-compare-base />
                <img src="/assets/images/pretrain/realworld_shared_pca_ours_2.png" alt="Ours representation comparison 2" class="compare-top" data-compare-top />
                <span class="compare-label compare-label-left">Ours</span>
                <span class="compare-label compare-label-right" data-compare-baseline-label>UniGarment</span>
                <div class="compare-handle" data-compare-handle>
                  <div class="compare-divider" data-compare-divider></div>
                  <div class="compare-arrows" aria-hidden="true">
                    <span class="compare-arrow left"></span>
                    <span class="compare-arrow right"></span>
                  </div>
                </div>
                <input type="range" min="0" max="100" value="50" aria-label="Compare representations 2" class="compare-slider" data-compare-slider />
              </div>
            </div>
          </section>

          <section class="theme-surface mx-auto w-full rounded-2xl bg-white p-4">
            <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">{flowMatching.title}</h2>
            <div class="theme-subtle mb-4 rounded-2xl bg-stone-50/80 px-4 py-3 ring-1 ring-stone-100">
              <p class="theme-copy copy-sans text-center text-md leading-7 text-stone-700">
                {flowMatching.description}
              </p>
            </div>

            <div class="mx-auto mt-4 w-full max-w-[50%] overflow-hidden rounded-2xl bg-stone-50 p-2">
              <div class="flow-video-frame">
                <video data-autoplay-visible muted playsinline loop preload="none" poster="/assets/posters/flow-matching.jpg" disablepictureinpicture controlslist="nodownload noplaybackrate nofullscreen noremoteplayback" class="flow-video mx-auto w-full bg-black">
                  <source src={flowMatching.video} type="video/mp4" />
                </video>
              </div>
            </div>
          </section>

          {rolloutModes.length > 0 && (
            <section class="theme-surface section-deferred rounded-2xl bg-white p-6">
              <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">
                Simulation Rollouts on Unseen Meshes
              </h2>

              <div class="theme-subtle mb-3 rounded-2xl bg-stone-50/80 px-4 py-3 ring-1 ring-stone-100">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                  <p class="theme-copy copy-sans max-w-3xl text-md leading-7 text-stone-700">
                    We show different simulation rollouts for folding modes both seen and unseen during training.
                  </p>
                  <div class="theme-pill inline-flex items-center gap-2 self-start rounded-full border border-stone-200 bg-white px-3 py-1 shadow-sm">
                    <span class="theme-meta font-poppins text-[11px] font-medium uppercase tracking-[0.18em] text-stone-500">
                      Mode
                    </span>
                    <select
                      data-rollout-picker
                      class="theme-link min-w-[7.5rem] bg-transparent text-sm font-medium text-stone-700 outline-none"
                    >
                      <optgroup label="Seen">
                        {rolloutModes.filter((mode) => mode.group === "seen").map((mode) => (
                          <option value={mode.key} selected={mode.key === defaultRolloutMode?.key}>
                            {mode.shortLabel}
                          </option>
                        ))}
                      </optgroup>
                      <optgroup label="Unseen">
                        {rolloutModes.filter((mode) => mode.group === "unseen").map((mode) => (
                          <option value={mode.key}>{mode.shortLabel}</option>
                        ))}
                      </optgroup>
                    </select>
                  </div>
                </div>
                <div class="mt-3 space-y-1" data-rollout-copy>
                  <div class="theme-meta flex flex-wrap items-center gap-2 text-sm text-stone-500">
                    <span
                      class="theme-pill rounded-full bg-white px-2.5 py-1 font-poppins text-[11px] font-medium uppercase tracking-[0.16em] text-stone-500 ring-1 ring-stone-200"
                      data-rollout-group
                    >
                      {defaultRolloutMode?.group === "seen" ? "Seen" : "Unseen"}
                    </span>
                    <span class="theme-link font-poppins text-sm font-medium text-stone-700" data-rollout-label>
                      {defaultRolloutMode?.fullLabel}
                    </span>
                    <span class="theme-meta copy-sans text-sm text-stone-500" data-rollout-descriptor>
                      {defaultRolloutMode?.descriptor}
                    </span>
                  </div>
                  <p class="theme-copy copy-sans w-full text-sm leading-6 text-stone-600" data-rollout-instruction>
                    {defaultRolloutMode?.instruction}
                  </p>
                </div>
              </div>

              <section class="space-y-1">
                <figure class="rollout-fade-target theme-soft-card w-full max-w-4xl overflow-hidden bg-white pt-2 pb-3" data-rollout-fade>
                  {defaultRolloutMode?.preview ? (
                    <div class="flex h-36 w-full items-start justify-start">
                      <img
                        data-rollout-preview
                        src={defaultRolloutMode.preview}
                        alt={`${defaultRolloutMode.group === "seen" ? "Seen" : "Unseen"} rollout preview`}
                        class="h-full w-full object-contain object-left"
                        loading="eager"
                      />
                    </div>
                  ) : (
                    <div class="flex h-36 items-center justify-center text-center">
                      <p class="theme-meta copy-sans px-4 text-sm text-stone-500">Preview placeholder</p>
                    </div>
                  )}
                </figure>

                <div class="rollout-fade-target grid gap-3 grid-cols-2 lg:grid-cols-6" data-rollout-grid data-rollout-fade>
                  {defaultRolloutMode?.videos.slice(0, 12).map((video, index) => (
                    <figure class="overflow-hidden" data-rollout-card data-rollout-index={index}>
                      <video
                        data-rollout-video
                        data-autoplay-visible
                        muted
                        playsinline
                        loop
                        preload="none"
                        class="rollout-video mx-auto h-auto w-full object-contain"
                      >
                        <source data-rollout-video-source src={video} type="video/mp4" />
                      </video>
                    </figure>
                  ))}
                </div>
              </section>
          </section>
          )}
            <section class="theme-surface section-deferred rounded-2xl bg-white p-6">
            <h2 class="font-poppins mb-4 text-center text-3xl font-semibold">
              {zeroShotSim2Real.title}
            </h2>
            <div class="theme-subtle mb-4 rounded-2xl bg-stone-50/80 px-4 py-3 ring-1 ring-stone-100">
              <p class="theme-copy copy-sans text-center text-md leading-7 text-stone-700">
                  Our policy transfers zero-shot to the real world without any real-world data collection or fine-tuning and instantly executes the intended folding strategy from a single human demonstration without requiring robot demonstrations.
              </p>
            </div>

            <div class="grid gap-3 md:grid-cols-2">
              {zeroShotSim2Real.videos.map((item) => (
                <figure class="theme-soft-card overflow-hidden rounded-2xl bg-stone-50 p-3">
                  <video
                    data-sync-group="one-shot"
                    data-autoplay-visible
                    muted
                    playsinline
                    controls
                    preload="none"
                    poster={item.video.replace("/assets/videos/one-shot-videos/", "/assets/posters/one-shot/").replace(".mp4", ".jpg")}
                    class="mx-auto h-auto max-h-[32rem] w-full rounded-xl bg-black object-contain"
                  >
                    <source src={item.video} type="video/mp4" />
                  </video>
                  {item.label && (
                    <figcaption class="theme-meta font-poppins mt-3 text-center text-sm text-stone-600">
                      {item.label}
                    </figcaption>
                  )}
                </figure>
              ))}
            </div>
          </section>

          <section class="theme-surface section-deferred rounded-2xl bg-white p-6">
            <div class="mb-3 flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
              <h2 class="font-poppins text-center text-xl font-semibold">More Examples</h2>
              <div class="theme-soft-card inline-flex flex-wrap justify-center gap-1 rounded-full bg-stone-100 p-1">
                {Object.entries(videoSets).map(([key, set], index) => (
                  <button
                    type="button"
                    data-video-set={key}
                    aria-pressed={index === 0 ? "true" : "false"}
                    class="font-poppins cursor-pointer rounded-full px-4 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-200 hover:text-stone-900"
                  >
                    {set.label}
                  </button>
                ))}
              </div>
            </div>

            <div class="grid gap-3 md:grid-cols-2">
              {defaultSet.videos.map((item, index) => (
                <figure class="more-example-card theme-soft-card relative overflow-hidden rounded-2xl bg-stone-50 p-3" data-grid-card>
                  <div class="more-example-loading" data-grid-loading aria-hidden="true">
                    <span class="more-example-spinner"></span>
                    <span class="font-poppins text-[11px] font-medium uppercase tracking-[0.18em] text-stone-500" data-grid-loading-label>
                      Loading video
                    </span>
                  </div>
                  <video
                    data-grid-video
                    data-index={index}
                    data-autoplay-visible
                    muted
                    playsinline
                    loop
                    preload="metadata"
                    class="more-example-video mx-auto h-auto max-h-[32rem] w-full rounded-xl bg-black object-contain"
                  >
                    <source src={item.video} type="video/mp4" />
                  </video>
                  <figcaption
                    data-grid-caption
                    class="theme-meta font-poppins mt-3 text-center text-sm text-stone-600"
                  >
                    {item.label}
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>

          {failureModes?.modes?.length > 0 && (
            <section class="theme-surface section-deferred rounded-2xl bg-white p-6">
              <div class="mb-4 flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
                <h2 class="font-poppins text-center text-xl font-semibold">{failureModes.title}</h2>
                <div class="theme-soft-card inline-flex flex-wrap justify-center gap-1 rounded-full bg-stone-100 p-1">
                  {failureModes.modes.map((mode, index) => (
                    <button
                      type="button"
                      data-failure-mode={mode.key}
                      aria-pressed={index === 0 ? "true" : "false"}
                      class="font-poppins cursor-pointer rounded-full px-4 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-200 hover:text-stone-900"
                    >
                      {mode.label}
                    </button>
                  ))}
                </div>
              </div>

              <div class="grid gap-4 lg:grid-cols-[1.35fr_0.95fr]">
                <figure class="theme-soft-card overflow-hidden rounded-2xl bg-stone-50 p-3">
                  <video
                    data-failure-video
                    data-autoplay-visible
                    muted
                    playsinline
                    loop
                    preload="none"
                    poster="/assets/posters/failures/failure_workspace_limits.jpg"
                    class="mx-auto h-auto w-full bg-black object-contain"
                  >
                    <source src={defaultFailureMode?.video} type="video/mp4" />
                  </video>
                </figure>

                <div class="theme-subtle flex h-full flex-col justify-start rounded-2xl px-5 py-5 text-left">
                  <p class="theme-meta font-poppins text-sm font-medium uppercase tracking-[0.18em] text-stone-500">
                    {failureModes.description}
                  </p>
                  <h3 class="font-poppins mt-3 min-h-[3.5rem] text-2xl font-semibold text-stone-900" data-failure-label>
                    {defaultFailureMode?.label}
                  </h3>
                  <p class="theme-copy copy-sans mt-3 min-h-[10.5rem] text-base leading-7 text-stone-700" data-failure-description>
                    {defaultFailureMode?.description}
                  </p>
                </div>
              </div>
            </section>
          )}
        </div>
      </section>
    </div>

    <footer class="theme-footer mt-6 bg-stone-50 py-6">
      <div class="flex justify-center">
        <a href="#top" class="theme-link font-poppins text-base text-black transition hover:scale-105">
          Back to Top
        </a>
      </div>
    </footer>
  </main>

  <script id="video-sets" type="application/json" set:html={serializedVideoSets}></script>
  <script id="failure-modes" type="application/json" set:html={serializedFailureModes}></script>
  <script id="rollout-modes" type="application/json" set:html={serializedRolloutModes}></script>
  <script is:inline>
    const initCompareSliders = () => {
      const compareCards = [...document.querySelectorAll("[data-compare]")];
      const baselineButtons = [...document.querySelectorAll("[data-baseline]")];
      const baselineLabels = [...document.querySelectorAll("[data-compare-baseline-label]")];
      let baseline = "unigarment";
      const baselineText = {
        unigarment: "UniGarment",
        dino: "DINOv3",
      };

      const updateCard = (card, value) => {
              const topImage = card.querySelector("[data-compare-top]");
              const divider = card.querySelector("[data-compare-divider]");
              const slider = card.querySelector("[data-compare-slider]");
              const leftLabel = card.querySelector(".compare-label-left");
              const rightLabel = card.querySelector(".compare-label-right");
              const leftUni = card.dataset.leftUnigarment;
              const leftDino = card.dataset.leftDino;
              const rightSrc = card.dataset.rightSrc;
              const base = card.querySelector("[data-compare-base]");

        if (!topImage || !divider || !slider || !base) return;

        const pct = Math.max(0, Math.min(100, value));
        const src = baseline === "dino" ? leftDino : leftUni;
        const fadeEdge = 18;
        const leftOpacity = Math.max(0, Math.min(1, (pct - 8) / fadeEdge));
        const rightOpacity = Math.max(0, Math.min(1, (92 - pct) / fadeEdge));

        base.src = src;
        topImage.src = rightSrc;
        topImage.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
        divider.style.left = `${pct}%`;
        card.style.setProperty("--slider-x", `${pct}%`);
        if (leftLabel) {
          leftLabel.style.opacity = String(leftOpacity);
          leftLabel.style.transform = `translateX(${Math.max(-10, (pct - 50) * -0.12)}px)`;
        }
        if (rightLabel) {
          rightLabel.style.opacity = String(rightOpacity);
          rightLabel.style.transform = `translateX(${Math.min(10, (pct - 50) * 0.12)}px)`;
        }
        slider.value = String(pct);
      };

      const refresh = () => {
        compareCards.forEach((card) => {
          const slider = card.querySelector("[data-compare-slider]");
          if (!slider) return;
          updateCard(card, Number(slider.value || 50));
        });
        baselineLabels.forEach((label) => {
          label.textContent = baselineText[baseline] || "Baseline";
        });
      };

      const applyBaseline = (name) => {
        baseline = name || "unigarment";
        baselineButtons.forEach((btn) => {
          const active = btn.dataset.baseline === baseline;
          btn.setAttribute("aria-pressed", active ? "true" : "false");
          btn.classList.toggle("text-stone-950", active);
          btn.classList.toggle("text-stone-600", !active);
        });
        refresh();
      };

      baselineButtons.forEach((button) => {
        button.addEventListener("click", () => applyBaseline(button.dataset.baseline));
        button.addEventListener("mouseenter", () => applyBaseline(button.dataset.baseline));
        button.addEventListener("focus", () => applyBaseline(button.dataset.baseline));
      });

      compareCards.forEach((card) => {
        const slider = card.querySelector("[data-compare-slider]");
        if (!slider) return;
        slider.addEventListener("input", (event) => {
          updateCard(card, Number(event.target.value));
        });
      });

      applyBaseline(baseline);
    };

    let visibleAutoplayObserver;

    const observeVisibleAutoplay = (root = document) => {
      if (!visibleAutoplayObserver) return;
      root.querySelectorAll("video[data-autoplay-visible]").forEach((video) => visibleAutoplayObserver.observe(video));
    };

    const initRolloutGallery = () => {
      const rolloutModes = JSON.parse(document.getElementById("rollout-modes")?.textContent || "[]");
      if (!rolloutModes.length) return;

      const picker = document.querySelector("[data-rollout-picker]");
      const preview = document.querySelector("[data-rollout-preview]");
      const grid = document.querySelector("[data-rollout-grid]");
      const groupLabel = document.querySelector("[data-rollout-group]");
      const modeLabel = document.querySelector("[data-rollout-label]");
      const descriptorLabel = document.querySelector("[data-rollout-descriptor]");
      const instruction = document.querySelector("[data-rollout-instruction]");
      const fadeTargets = [...document.querySelectorAll("[data-rollout-fade]")];
      const cards = [...document.querySelectorAll("[data-rollout-card]")];
      const videos = [...document.querySelectorAll("[data-rollout-video]")];
      let fadeTimeout;

      let activeMode = picker?.value || rolloutModes[0].key;

      const applyMode = (key) => {
        const mode = rolloutModes.find((item) => item.key === key);
        if (!mode) return;

        fadeTargets.forEach((target) => target.classList.add("is-loading"));
        window.clearTimeout(fadeTimeout);

        activeMode = key;
        if (picker) picker.value = key;

        if (preview && mode.preview) {
          preview.src = mode.preview;
        }

        if (groupLabel) {
          groupLabel.textContent = mode.group === "seen" ? "Seen" : "Unseen";
        }

        if (modeLabel) {
          modeLabel.textContent = mode.fullLabel || mode.shortLabel || mode.label;
        }

        if (descriptorLabel) {
          descriptorLabel.textContent = mode.descriptor || "";
        }

        if (instruction) {
          instruction.textContent = mode.instruction || "";
        }

        if (!grid || !videos.length) return;

        videos.forEach((video, index) => {
          const source = video.querySelector("[data-rollout-video-source]");
          const card = cards[index];
          const nextSrc = mode.videos[index];

          if (!source || !card) return;

          if (!nextSrc) {
            video.pause();
            video.removeAttribute("src");
            source.removeAttribute("src");
            card.classList.add("hidden");
            return;
          }

          card.classList.remove("hidden");

          if (source.getAttribute("src") !== nextSrc) {
            source.src = nextSrc;
            video.load();
          }
        });

        observeVisibleAutoplay(grid);

        requestAnimationFrame(() => {
          videos.forEach((video, index) => {
            const card = cards[index];
            if (!card || card.classList.contains("hidden") || !video.paused) return;
            video.play().catch(() => {});
          });
        });

        fadeTimeout = window.setTimeout(() => {
          fadeTargets.forEach((target) => target.classList.remove("is-loading"));
        }, 140);
      };

      const onPickerChange = (event) => {
        applyMode(event.target.value);
      };

      picker?.addEventListener("change", onPickerChange);

      applyMode(activeMode);
    };

    const initSyncedVideos = () => {
      const groups = new Map();
      document.querySelectorAll("[data-sync-group]").forEach((video) => {
        const groupName = video.dataset.syncGroup;
        if (!groupName) return;
        if (!groups.has(groupName)) groups.set(groupName, []);
        groups.get(groupName).push(video);
      });

      groups.forEach((videos) => {
        if (!videos.length) return;

        let restarting = false;
        let maxDuration = 0;
        const visibility = new Map(videos.map((video) => [video, false]));

        const syncToStart = () => {
          restarting = true;
          videos.forEach((video) => {
            video.currentTime = 0;
            video.play().catch(() => {});
          });
          requestAnimationFrame(() => {
            restarting = false;
          });
        };

        videos.forEach((video) => {
          const updateDuration = () => {
            if (Number.isFinite(video.duration)) {
              maxDuration = Math.max(maxDuration, video.duration);
            }
          };

          video.addEventListener("loadedmetadata", updateDuration);
          video.addEventListener("ended", () => {
            if (restarting) return;
            const visibleCount = [...visibility.values()].filter(Boolean).length;
            if (visibleCount > 0 && (!Number.isFinite(maxDuration) || Math.abs(video.duration - maxDuration) < 0.05)) {
              syncToStart();
            }
          });
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            visibility.set(entry.target, entry.isIntersecting);
          });

          const visibleCount = [...visibility.values()].filter(Boolean).length;
          if (visibleCount > 0) {
            syncToStart();
          } else {
            videos.forEach((video) => video.pause());
          }
        }, { threshold: 0.35 });

        videos.forEach((video) => observer.observe(video));
      });
    };

    const initVisibleAutoplay = () => {
      visibleAutoplayObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (video.dataset.syncGroup) return;

          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      }, { threshold: 0.35 });

      observeVisibleAutoplay(document);
    };

    const initVideoSets = () => {
      const videoSets = JSON.parse(document.getElementById("video-sets")?.textContent || "{}");
      const setButtons = [...document.querySelectorAll("[data-video-set]")];
      const videos = [...document.querySelectorAll("[data-grid-video]")];
      const captions = [...document.querySelectorAll("[data-grid-caption]")];
      const cards = [...document.querySelectorAll("[data-grid-card]")];

      if (!setButtons.length || !videos.length) return;

      const setCardLoading = (card, loading, failed = false) => {
        if (!card) return;
        const label = card.querySelector("[data-grid-loading-label]");
        card.classList.toggle("is-loading", loading);
        card.classList.toggle("is-failed", failed);
        if (label) {
          label.textContent = failed ? "Video unavailable" : "Loading video";
        }
      };

      videos.forEach((video, index) => {
        const card = cards[index];
        if (!card) return;

        video.addEventListener("loadeddata", () => {
          setCardLoading(card, false, false);
        });

        video.addEventListener("canplay", () => {
          setCardLoading(card, false, false);
        });

        video.addEventListener("error", () => {
          setCardLoading(card, false, true);
        });
      });

      const applySet = (name) => {
        const nextSet = videoSets?.[name];
        if (!nextSet) return;

        videos.forEach((video, index) => {
          const source = video.querySelector("source");
          const caption = captions[index];
          const item = nextSet.videos[index];
          const card = video.closest("figure");

          if (!source || !card) return;

          if (item) {
            card.classList.remove("hidden");
            setCardLoading(card, true, false);
            if (caption) {
              caption.textContent = item.label;
            }

            if (source.getAttribute("src") !== item.video) {
              source.src = item.video;
              video.load();
            } else if (video.readyState >= 2) {
              setCardLoading(card, false, false);
            }

            video.play().catch(() => {});
          } else {
            video.pause();
            video.removeAttribute("src");
            source.removeAttribute("src");
            card.classList.add("hidden");
            setCardLoading(card, false, false);
          }
        });

        setButtons.forEach((button) => {
          const isActive = button.dataset.videoSet === name;
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
          button.classList.toggle("bg-white", isActive);
          button.classList.toggle("text-stone-950", isActive);
          button.classList.toggle("shadow-sm", isActive);
          button.classList.toggle("text-stone-600", !isActive);
        });
      };

      setButtons.forEach((button) => {
        button.addEventListener("click", () => applySet(button.dataset.videoSet));
      });

      applySet("pink");
    };

    const initFailureModes = () => {
      const failureModes = JSON.parse(document.getElementById("failure-modes")?.textContent || "{}");
      const modes = failureModes?.modes || [];
      if (!modes.length) return;

      const buttons = [...document.querySelectorAll("[data-failure-mode]")];
      const video = document.querySelector("[data-failure-video]");
      const label = document.querySelector("[data-failure-label]");
      const description = document.querySelector("[data-failure-description]");

      const applyMode = (key) => {
        const mode = modes.find((item) => item.key === key);
        if (!mode || !video) return;

        const source = video.querySelector("source");
        if (source) {
          source.src = mode.video;
          video.load();
          video.play().catch(() => {});
        }

        if (label) label.textContent = mode.label;
        if (description) description.textContent = mode.description;

        buttons.forEach((button) => {
          const active = button.dataset.failureMode === key;
          button.setAttribute("aria-pressed", active ? "true" : "false");
          button.classList.toggle("bg-white", active);
          button.classList.toggle("text-stone-950", active);
          button.classList.toggle("shadow-sm", active);
          button.classList.toggle("text-stone-600", !active);
        });
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => applyMode(button.dataset.failureMode));
      });

      applyMode(modes[0].key);
    };

    const init = () => {
      initCompareSliders();
      initVisibleAutoplay();
      initRolloutGallery();
      initSyncedVideos();
      initVideoSets();
      initFailureModes();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  </script>
</BaseLayout>
